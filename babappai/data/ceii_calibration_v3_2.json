  "raw_eii_definition": "eii_z_raw = (D_obs - mu0) / max(sigma0_raw, sigma_floor), eii_01_raw = sigmoid(eii_z_raw)",
  "calibration_semantics": "cEII is a conditional calibrated identifiability probability valid only when applicability criteria are satisfied; otherwise calibration abstains.",
