  },
  "target_definitions": {
    "R_gene": "0.55*branch_rank_norm + 0.30*burden_alignment + 0.15*(scenario_branch_stability * max(branch_rank_norm, burden_alignment)); NaN branch rank fallback=0.0",
    "R_site": "0.50*site_enrichment_at_k + 0.35*site_rank_norm + 0.15*(scenario_site_stability * max(site_enrichment_at_k, site_rank_norm)); NaN site rank fallback=0.0",
    "excess_over_neutral_gate": "excess_evidence_score >= 0.3500 AND excess_evidence_score combines nonnegative contributions from -log10(q_emp), dispersion_ratio, and eii_01_raw",
    "I_gene_recovery_only": "1 if R_gene >= 0.26 else 0",
    "I_site_recovery_only": "1 if R_site >= 0.16 else 0",
    "I_gene": "1 if (I_gene_recovery_only == 1 AND excess_over_neutral_gate == 1) else 0",
    "I_site": "1 if (I_site_recovery_only == 1 AND excess_over_neutral_gate == 1) else 0"
  },
